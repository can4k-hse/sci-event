{
  "name": "sci-event-frontend",
  "version": "1.0.0",
  "packageManager": "npm@10.0.0",
  "private": true,
  "description": "Frontend monorepo for sci-event",
  "workspaces": [
    "apps/*",
    "lib/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}